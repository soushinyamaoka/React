# StockHome 本番環境変数（docker-compose.prod.yml 用）
# このファイルを .env にコピーして値を設定してください:
#   cp .env.production.example .env
# ※ ルートの .env は .gitignore 済み（コミットされません）

# --- PostgreSQL ---
POSTGRES_USER=stockhome
POSTGRES_PASSWORD=__change_me_strong_password__
POSTGRES_DB=stockhome

# --- API ---
# 長いランダム文字列を推奨（例: openssl rand -base64 48 で生成）
JWT_SECRET=__change_me_long_random_secret__

# --- GAS ブリッジ連携 ---
# GAS（Gmail取込/ReadyGo通知ブリッジ）との共有シークレット
# GAS 側スクリプトプロパティ STOCKHOME_BRIDGE_TOKEN と同じ値にする
BRIDGE_TOKEN=__change_me_bridge_token__
