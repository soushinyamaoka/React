{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@homeasset/shared": ["../../packages/shared/dist/index.d.ts"],
      "@homeasset/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*"]
}
