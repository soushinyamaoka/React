# モバイルアプリの接続先 VPS API。
# このファイル（.env.example）はコミットされます。実値は書かないこと。
#
# セットアップ（PC ごとに1回）:
#   cp apps/mobile/.env.example apps/mobile/.env
#   そして .env の URL を実際の VPS アドレスに書き換える
#
# vps モード（npm run app:start）で参照されます。
# local モード（npm run app:start:local）では無視され、PC の LAN IP が自動判定されます。
EXPO_PUBLIC_API_BASE_URL=http://<your-vps-ip>:4002

# Expo アカウント名（app.config.js の owner で参照。EAS Build/Update に必要）
EXPO_OWNER=<your-expo-username>
