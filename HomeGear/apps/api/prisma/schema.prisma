// HomeGear DB スキーマ
// PostgreSQL + Prisma
// 家庭単位 (household_id) でデータを分離する

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members            HouseholdMember[]
  devices            Device[]
  categories         Category[]
  locations          Location[]
  deviceSpecs        DeviceSpec[]
  deviceLinks        DeviceLink[]
  maintenanceRecords MaintenanceRecord[]
  repairRecords      RepairRecord[]
  consumables        Consumable[]
  networkInfos       NetworkInfo[]
  accessories        Accessory[]
  aiImportLogs       AiImportLog[]

  @@map("households")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships HouseholdMember[]

  @@map("users")
}

model HouseholdMember {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  userId      String   @map("user_id")
  role        String   @default("member") // owner | member
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
  @@map("household_members")
}

model Category {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  name        String
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  devices   Device[]

  @@unique([householdId, name])
  @@index([householdId])
  @@map("categories")
}

model Location {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  name        String
  parentId    String?  @map("parent_id")
  memo        String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent    Location?  @relation("LocationParent", fields: [parentId], references: [id])
  children  Location[] @relation("LocationParent")
  devices   Device[]

  @@unique([householdId, name])
  @@index([householdId])
  @@map("locations")
}

model Device {
  id                  String   @id @default(cuid())
  householdId         String   @map("household_id")
  name                String
  categoryId          String?  @map("category_id")
  manufacturer        String?
  modelNumber         String?  @map("model_number")
  serialNumber        String?  @map("serial_number")
  locationId          String?  @map("location_id")
  status              String   @default("in_use")
  priority            String   @default("medium")
  purchaseDate        DateTime? @map("purchase_date") @db.Date
  purchaseStore       String?  @map("purchase_store")
  purchasePrice       Decimal? @map("purchase_price") @db.Decimal(12, 2)
  purchaseUrl         String?  @map("purchase_url")
  orderNumber         String?  @map("order_number")
  warrantyStartDate   DateTime? @map("warranty_start_date") @db.Date
  warrantyEndDate     DateTime? @map("warranty_end_date") @db.Date
  hasExtendedWarranty Boolean  @default(false) @map("has_extended_warranty")
  warrantyMemo        String?  @map("warranty_memo")
  manualUrl           String?  @map("manual_url")
  officialUrl         String?  @map("official_url")
  supportUrl          String?  @map("support_url")
  photoUrl            String?  @map("photo_url")
  labelPhotoUrl       String?  @map("label_photo_url")
  installationPhotoUrl String? @map("installation_photo_url")
  memo                String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  household          Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id])
  location           Location?           @relation(fields: [locationId], references: [id])
  specs              DeviceSpec[]
  links              DeviceLink[]
  maintenanceRecords MaintenanceRecord[]
  repairRecords      RepairRecord[]
  consumables        Consumable[]
  networkInfo        NetworkInfo?
  accessories        Accessory[]
  aiImportLogs       AiImportLog[]

  @@index([householdId])
  @@index([householdId, status])
  @@index([householdId, deletedAt])
  @@map("devices")
}

model DeviceSpec {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  deviceId    String   @map("device_id")
  specName    String   @map("spec_name")
  specValue   String?  @map("spec_value")
  unit        String?
  memo        String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("device_specs")
}

model DeviceLink {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  deviceId    String   @map("device_id")
  linkType    String   @map("link_type")
  title       String?
  url         String
  memo        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("device_links")
}

model MaintenanceRecord {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  deviceId        String   @map("device_id")
  maintenanceDate DateTime @map("maintenance_date") @db.Date
  maintenanceType String   @map("maintenance_type")
  description     String?
  cost            Decimal? @db.Decimal(12, 2)
  performedBy     String?  @map("performed_by")
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  photoUrl        String?  @map("photo_url")
  memo            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([householdId, nextDueDate])
  @@map("maintenance_records")
}

model RepairRecord {
  id                String   @id @default(cuid())
  householdId       String   @map("household_id")
  deviceId          String   @map("device_id")
  occurredDate      DateTime @map("occurred_date") @db.Date
  symptom           String?
  cause             String?
  actionTaken       String?  @map("action_taken")
  repairVendor      String?  @map("repair_vendor")
  repairTicketNumber String? @map("repair_ticket_number")
  cost              Decimal? @db.Decimal(12, 2)
  usedWarranty      Boolean  @default(false) @map("used_warranty")
  completedDate     DateTime? @map("completed_date") @db.Date
  status            String   @default("pending")
  memo              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("repair_records")
}

model Consumable {
  id                      String   @id @default(cuid())
  householdId             String   @map("household_id")
  deviceId                String   @map("device_id")
  name                    String
  manufacturer            String?
  modelNumber             String?  @map("model_number")
  replacementIntervalText String?  @map("replacement_interval_text")
  lastReplacedDate        DateTime? @map("last_replaced_date") @db.Date
  nextReplacementDate     DateTime? @map("next_replacement_date") @db.Date
  purchaseUrl             String?  @map("purchase_url")
  memo                    String?
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("consumables")
}

model NetworkInfo {
  id                    String   @id @default(cuid())
  householdId           String   @map("household_id")
  deviceId              String   @unique @map("device_id")
  ipAddress             String?  @map("ip_address")
  hostName              String?  @map("host_name")
  macAddress            String?  @map("mac_address")
  adminUrl              String?  @map("admin_url")
  port                  Int?
  connectionType        String?  @map("connection_type")
  credentialStorageMemo String?  @map("credential_storage_memo")
  settingsMemo          String?  @map("settings_memo")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("network_infos")
}

model Accessory {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  deviceId        String   @map("device_id")
  name            String
  quantity        Int?
  storageLocation String?  @map("storage_location")
  memo            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("accessories")
}

model AiImportLog {
  id            String   @id @default(cuid())
  householdId   String   @map("household_id")
  deviceId      String?  @map("device_id")
  sourceAiName  String?  @map("source_ai_name")
  inputPrompt   String?  @map("input_prompt")
  rawResponse   String?  @map("raw_response")
  parsedJson    Json?    @map("parsed_json")
  importedAt    DateTime @default(now()) @map("imported_at")
  memo          String?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  device    Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@map("ai_import_logs")
}
