# HomeAsset 本番環境変数（docker-compose.prod.yml 用）
# このファイルを .env にコピーして値を設定してください:
#   cp .env.production.example .env
# ※ ルートの .env は .gitignore 済み（コミットされません）

# --- PostgreSQL ---
POSTGRES_USER=homeasset
POSTGRES_PASSWORD=__change_me_strong_password__
POSTGRES_DB=homeasset

# --- API ---
# 長いランダム文字列を推奨（例: openssl rand -base64 48 で生成）
JWT_SECRET=__change_me_long_random_secret__
